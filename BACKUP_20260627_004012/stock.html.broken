<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stock - Whitestone Dynamic</title>
    <link rel="stylesheet" href="css/style.css">
    <style>
        /* ===== STOCK MANAGEMENT STYLES ===== */
        
        .stats-grid {
            display: grid !important;
            grid-template-columns: repeat(8, 1fr) !important;
            gap: 10px !important;
            margin-bottom: 16px !important;
        }
        .stat-card {
            padding: 14px 16px !important;
            gap: 12px !important;
            border-radius: 10px !important;
            background: var(--bg-white);
            border: 1px solid var(--border-light);
            box-shadow: var(--shadow-sm);
            transition: all 0.2s;
            display: flex !important;
            align-items: center !important;
        }
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }
        .stat-card .stat-icon {
            font-size: 28px !important;
            flex-shrink: 0;
        }
        .stat-card .stat-info {
            flex: 1;
            min-width: 0;
        }
        .stat-card .stat-info h3 {
            font-size: 9px !important;
            text-transform: uppercase;
            color: var(--text-muted);
            font-weight: 600;
            letter-spacing: 0.3px;
            margin-bottom: 1px;
        }
        .stat-card .stat-info p {
            font-size: 20px !important;
            font-weight: 700;
            color: var(--navy);
            line-height: 1.2;
        }
        .stat-card .stat-change {
            font-size: 8px !important;
            color: var(--text-muted);
            display: block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* ===== PRODUCT CARDS ===== */
        .product-grid {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 16px;
        }
        .product-card {
            background: var(--bg-white);
            border-radius: var(--radius-md);
            border: var(--border-light);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }
        .product-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 18px;
            background: var(--bg-secondary);
            cursor: pointer;
            transition: var(--transition);
            flex-wrap: wrap;
            gap: 8px;
        }
        .product-header:hover {
            background: #e8e4e0;
        }
        .product-header .product-name {
            font-size: 15px;
            font-weight: 700;
            color: var(--navy);
        }
        .product-header .product-category {
            font-size: 10px;
            font-weight: 600;
            padding: 2px 12px;
            border-radius: 12px;
            text-transform: uppercase;
        }
        .product-header .product-category.feed { background: #D5F5E3; color: #1E8449; }
        .product-header .product-category.egg { background: #FDEBD0; color: #935E38; }
        .product-header .product-category.bird { background: #D6EAF8; color: #1A5276; }
        .product-header .product-category.med { background: #E8DAEF; color: #6C3483; }
        .product-header .product-category.equip { background: #E5E7E9; color: #5D6D7E; }
        .product-header .product-category.pack { background: #F6DDCC; color: #A04000; }
        
        .product-header .product-total {
            font-size: 13px;
            color: var(--text-secondary);
        }
        .product-header .product-total strong {
            color: var(--navy);
        }
        .product-toggle {
            font-size: 12px;
            color: var(--text-muted);
            transition: transform 0.2s;
            background: none;
            border: none;
            cursor: pointer;
        }
        .product-toggle.open {
            transform: rotate(180deg);
        }

        .variant-table-wrap {
            overflow-x: auto;
            padding: 0 4px;
        }
        .variant-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
            min-width: 600px;
        }
        .variant-table thead th {
            padding: 6px 10px;
            text-align: left;
            font-weight: 600;
            font-size: 9px;
            text-transform: uppercase;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-light);
            background: #faf8f6;
        }
        .variant-table tbody td {
            padding: 6px 10px;
            border-bottom: 1px solid var(--border-light);
            color: var(--text-secondary);
        }
        .variant-table tbody tr:hover {
            background: var(--bg-hover);
        }
        .variant-table .variant-name {
            font-weight: 500;
            color: var(--navy);
        }
        .variant-table .low-stock {
            color: #DC3545;
            font-weight: 600;
        }
        .variant-table .out-of-stock {
            color: #DC3545;
            font-weight: 700;
        }

        .action-btn-sm {
            padding: 2px 8px;
            border: none;
            border-radius: 3px;
            cursor: pointer;
            font-size: 10px;
            font-weight: 500;
            transition: var(--transition);
            font-family: 'Inter', sans-serif;
            margin: 0 2px;
        }
        .action-btn-sm.edit {
            background: var(--navy);
            color: #fff;
        }
        .action-btn-sm.edit:hover {
            background: var(--navy-light);
        }
        .action-btn-sm.delete {
            background: #DC3545;
            color: #fff;
        }
        .action-btn-sm.delete:hover {
            background: #C82333;
        }
        .action-btn-sm.add-variant {
            background: #28A745;
            color: #fff;
        }
        .action-btn-sm.add-variant:hover {
            background: #1E7E34;
        }

        .empty-state {
            text-align: center;
            padding: 30px 20px;
            color: #888;
        }
        .empty-state .icon {
            font-size: 32px;
            display: block;
            margin-bottom: 6px;
            opacity: 0.5;
        }

        /* ===== MODAL ===== */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        .modal-overlay.show { display: flex; }
        .modal-box {
            background: #fff;
            padding: 24px 28px;
            border-radius: 12px;
            width: 100%;
            max-width: 460px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 8px 30px rgba(0,0,0,0.2);
            animation: slideIn 0.3s ease;
        }
        @keyframes slideIn {
            from { transform: translateY(-20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .modal-box h2 {
            font-size: 17px;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 16px;
        }
        .modal-box h2::after {
            content: '';
            display: block;
            width: 30px;
            height: 2px;
            background: var(--navy);
            margin-top: 4px;
        }
        .modal-box .close-btn {
            float: right;
            font-size: 22px;
            cursor: pointer;
            color: #888;
            background: none;
            border: none;
            transition: var(--transition);
        }
        .modal-box .close-btn:hover {
            color: var(--navy);
            transform: rotate(90deg);
        }
        .modal-box .form-group {
            margin-bottom: 10px;
        }
        .modal-box .form-group label {
            display: block;
            color: var(--text-secondary);
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 2px;
        }
        .modal-box .form-group input,
        .modal-box .form-group select {
            width: 100%;
            padding: 6px 10px;
            background: var(--bg-secondary);
            border: var(--border-light);
            border-radius: var(--radius-sm);
            font-size: 12px;
            font-family: 'Inter', sans-serif;
            transition: var(--transition);
        }
        .modal-box .form-group input:focus,
        .modal-box .form-group select:focus {
            outline: none;
            border-color: var(--navy);
        }
        .modal-box .form-actions {
            display: flex;
            gap: 8px;
            margin-top: 14px;
        }
        .modal-box .form-actions button {
            padding: 6px 18px;
            border: none;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-weight: 600;
            font-size: 11px;
            font-family: 'Inter', sans-serif;
            transition: var(--transition);
        }
        .modal-box .form-actions .save-btn {
            background: var(--navy);
            color: #fff;
        }
        .modal-box .form-actions .save-btn:hover {
            background: var(--navy-light);
        }
        .modal-box .form-actions .cancel-btn {
            background: var(--bg-secondary);
            color: var(--text-secondary);
        }
        .modal-box .form-actions .cancel-btn:hover {
            background: #e8e4e0;
        }

        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            padding: 10px 20px;
            border-radius: 8px;
            color: #fff;
            font-weight: 500;
            font-size: 11px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            z-index: 2000;
            animation: slideIn 0.3s ease;
            font-family: 'Inter', sans-serif;
            display: none;
        }
        .toast.show { display: block; }
        .toast.success { background: #28A745; }
        .toast.error { background: #DC3545; }
        .toast.info { background: var(--navy); }

        .expiry-note {
            font-size: 8px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 1200px) {
            .stats-grid { grid-template-columns: repeat(4, 1fr) !important; }
        }
        @media (max-width: 992px) {
            .fcr-container { flex-direction: column; }
        }
        @media (max-width: 768px) {
            .stats-grid { grid-template-columns: 1fr 1fr !important; }
            .stat-card .stat-info p { font-size: 17px !important; }
            .stat-card .stat-icon { font-size: 22px !important; }
            .product-header { flex-direction: column; align-items: stretch; }
            .product-header .product-total { font-size: 11px; }
            .modal-box { padding: 18px 20px; margin: 10px; }
            .variant-table { min-width: 400px; font-size: 10px; }
            .variant-table thead th, .variant-table tbody td { padding: 4px 6px; }
        }
        @media (max-width: 480px) {
            .stats-grid { grid-template-columns: 1fr 1fr !important; }
            .stat-card .stat-info p { font-size: 14px !important; }
            .variant-table { min-width: 320px; font-size: 9px; }
        }
    </style>
</head>

<body>
    <div class="dashboard-container">
        <nav class="sidebar">
            <div class="sidebar-header">
                <h2>WHITESTONE</h2>
                <span>DYNAMIC</span>
                <div class="sidebar-divider"></div>
                <p>Poultry Management</p>
            </div>
            <ul class="nav-menu" id="mainNav">
                <li><a href="dashboard.html"><span class="icon">📊</span> <span>Dashboard</span></a></li>
                <li><a href="employees.html"><span class="icon">👥</span> <span>Employees</span></a></li>
                <li><a href="stock.html" class="active"><span class="icon">📦</span> <span>Stock</span></a></li>
                <li><a href="feed.html"><span class="icon">🌾</span> <span>Feed Management</span></a></li>
                <li><a href="coops.html"><span class="icon">🏠</span> <span>Coops</span></a></li>
                <li><a href="eggs.html"><span class="icon">🥚</span> <span>Egg Production</span></a></li>
                <li><a href="sales.html"><span class="icon">💰</span> <span>Sales</span></a></li>
                <li><a href="chickens.html"><span class="icon">🐔</span> <span>Chickens</span></a></li>
                <li><a href="customers.html"><span class="icon">👤</span> <span>Customers</span></a></li>
                <li><a href="batches.html"><span class="icon">📋</span> <span>Batches</span></a></li>
                <li><a href="pricing.html"><span class="icon">🏷️</span> <span>Pricing</span></a></li>
                <li><a href="security.html"><span class="icon">🔒</span> <span>Security</span></a></li>
                <li><a href="equipment.html"><span class="icon">🔧</span> <span>Equipment</span></a></li>
                <li><a href="#" id="logoutBtn"><span class="icon">🚪</span> <span>Logout</span></a></li>
            </ul>
        </nav>

        <main class="main-content">
            <header class="top-bar">
                <div class="top-bar-left">
                    <h1>📦 Stock Management</h1>
                    <p class="welcome-text">Monitor poultry and egg inventory in real-time</p>
                </div>
                <div class="top-bar-right">
                    <span class="date-display" id="currentDate"></span>
                    <div class="user-avatar" id="userAvatar">JA</div>
                </div>
            </header>

            <!-- Stats Grid -->
            <section class="stats-grid" id="statsGrid">
                <div class="stat-card">
                    <div class="stat-icon">🥚</div>
                    <div class="stat-info">
                        <h3>Total Eggs</h3>
                        <p id="statTotalEggs">0</p>
                        <span class="stat-change">In stock</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">🐔</div>
                    <div class="stat-info">
                        <h3>Total Birds</h3>
                        <p id="statBirds">0</p>
                        <span class="stat-change">In stock</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">🌾</div>
                    <div class="stat-info">
                        <h3>Feed Stock</h3>
                        <p id="statFeed">0 kg</p>
                        <span class="stat-change">Total feed</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">💊</div>
                    <div class="stat-info">
                        <h3>Vaccines &amp; Meds</h3>
                        <p id="statMeds">0</p>
                        <span class="stat-change">Items in stock</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">💰</div>
                    <div class="stat-info">
                        <h3>Inventory Value</h3>
                        <p id="statTotalValue">R0.00</p>
                        <span class="stat-change">Total stock value</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">📊</div>
                    <div class="stat-info">
                        <h3>Stock Turnover</h3>
                        <p id="statTurnover">0.0x</p>
                        <span class="stat-change">Times per month</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">⚠️</div>
                    <div class="stat-info">
                        <h3>Low Stock Alerts</h3>
                        <p id="statLowStock">0</p>
                        <span class="stat-change" id="lowStockDetails">No alerts</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">📅</div>
                    <div class="stat-info">
                        <h3>Feed Days Remaining</h3>
                        <p id="statFeedDays">0</p>
                        <span class="stat-change">Days of feed left</span>
                    </div>
                </div>
            </section>

            <!-- Category Filter -->
            <div class="category-filter" id="categoryFilter">
                <button class="category-btn active" data-category="all" onclick="filterByCategory('all')">All <span class="count" id="countAll">0</span></button>
                <button class="category-btn" data-category="bird" onclick="filterByCategory('bird')">Birds <span class="count" id="countBird">0</span></button>
                <button class="category-btn" data-category="feed" onclick="filterByCategory('feed')">Feed <span class="count" id="countFeed">0</span></button>
                <button class="category-btn" data-category="egg" onclick="filterByCategory('egg')">Eggs <span class="count" id="countEgg">0</span></button>
                <button class="category-btn" data-category="med" onclick="filterByCategory('med')">Medications <span class="count" id="countMed">0</span></button>
                <button class="category-btn" data-category="equip" onclick="filterByCategory('equip')">Equipment <span class="count" id="countEquip">0</span></button>
                <button class="category-btn" data-category="pack" onclick="filterByCategory('pack')">Packaging <span class="count" id="countPack">0</span></button>
            </div>

            <!-- Add Product Button -->
            <div style="margin-bottom:14px;display:flex;gap:8px;flex-wrap:wrap;">
                <button class="primary-btn" onclick="openAddProductModal()">+ Add Product</button>
                <button class="primary-btn" style="background:#28A745;" onclick="openAddVariantModal()">+ Add Variant</button>
            </div>

            <!-- Product Grid -->
            <div id="productGrid" class="product-grid">
                <div class="empty-state">
                    <span class="icon">📦</span>
                    <p>Loading stock...</p>
                </div>
            </div>
        </main>
    </div>

    <!-- Add/Edit Product Modal -->
    <div class="modal-overlay" id="productModal">
        <div class="modal-box">
            <button class="close-btn" onclick="closeProductModal()">&times;</button>
            <h2 id="productModalTitle">Add Product</h2>
            <form id="productForm" onsubmit="saveProduct(event)">
                <input type="hidden" id="editProductId">
                <div class="form-group">
                    <label>Product Name *</label>
                    <input type="text" id="productName" required placeholder="e.g. Layer Mash">
                </div>
                <div class="form-group">
                    <label>Category *</label>
                    <select id="productCategory" required>
                        <option value="bird">Birds</option>
                        <option value="feed">Feed</option>
                        <option value="egg">Eggs</option>
                        <option value="med">Medications</option>
                        <option value="equip">Equipment</option>
                        <option value="pack">Packaging</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <input type="text" id="productDescription" placeholder="Optional description">
                </div>
                <div class="form-actions">
                    <button type="submit" class="save-btn">Save Product</button>
                    <button type="button" class="cancel-btn" onclick="closeProductModal()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Add/Edit Variant Modal -->
    <div class="modal-overlay" id="variantModal">
        <div class="modal-box">
            <button class="close-btn" onclick="closeVariantModal()">&times;</button>
            <h2 id="variantModalTitle">Add Variant</h2>
            <form id="variantForm" onsubmit="saveVariant(event)">
                <input type="hidden" id="editVariantId">
                <input type="hidden" id="variantProductId">
                <div class="form-group">
                    <label>Product *</label>
                    <select id="variantProductSelect" required>
                        <option value="">Select product...</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Variant Name *</label>
                    <input type="text" id="variantName" required placeholder="e.g. 50kg Bag">
                </div>
                <div class="form-group">
                    <label>Supplier</label>
                    <input type="text" id="variantSupplier" placeholder="Supplier name">
                </div>
                <div class="form-group">
                    <label>Unit *</label>
                    <input type="text" id="variantUnit" required placeholder="e.g. kg, tray, carton">
                </div>
                <div class="form-group">
                    <label>Quantity *</label>
                    <input type="number" id="variantQuantity" required step="0.01">
                </div>
                <div class="form-group">
                    <label>Price (R)</label>
                    <input type="number" id="variantPrice" step="0.01">
                </div>
                <div class="form-group">
                    <label>Low Stock Threshold</label>
                    <input type="number" id="variantThreshold" value="10" min="0">
                </div>
                <div class="form-group">
                    <label>Expiry Date</label>
                    <input type="date" id="variantExpiry">
                    <div class="expiry-note">For feed, medications, and perishable items</div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="save-btn">Save Variant</button>
                    <button type="button" class="cancel-btn" onclick="closeVariantModal()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast"></div>

    <script>
        var API_URL = 'http://localhost:5500';
        var token = localStorage.getItem('token');
        if (!token) { window.location.href = 'login.html'; }

        var allProducts = [];
        var allVariants = [];
        var currentCategory = 'all';

        // ============================================
        // UTILITY FUNCTIONS
        // ============================================
        function formatCurrency(amount) {
            if (amount === undefined || amount === null) return 'R0.00';
            var num = parseFloat(amount);
            if (isNaN(num)) return 'R0.00';
            var parts = num.toFixed(2).split('.');
            var withSpaces = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
            return 'R' + withSpaces + '.' + parts[1];
        }

        function getCategoryLabel(cat) {
            var labels = {
                'bird': 'Birds',
                'feed': 'Feed',
                'egg': 'Eggs',
                'med': 'Medications',
                'equip': 'Equipment',
                'pack': 'Packaging'
            };
            return labels[cat] || cat;
        }

        function getCategoryClass(cat) {
            var classes = {
                'bird': 'bird',
                'feed': 'feed',
                'egg': 'egg',
                'med': 'med',
                'equip': 'equip',
                'pack': 'pack'
            };
            return classes[cat] || '';
        }

        function showToast(message, type) {
            var toast = document.getElementById('toast');
            toast.textContent = message;
            toast.className = 'toast ' + type + ' show';
            setTimeout(function() { toast.classList.remove('show'); }, 3000);
        }

        document.getElementById('currentDate').textContent = new Date().toLocaleDateString('en-US', {
            weekday: 'short', year: 'numeric', month: 'short', day: 'numeric'
        });

        // ============================================
        // LOAD USER
        // ============================================
        async function loadUser() {
            try {
                var res = await fetch(API_URL + '/api/auth/me', {
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                if (res.ok) {
                    var user = await res.json();
                    document.getElementById('userAvatar').textContent = (user.name || 'U')[0].toUpperCase();
                } else {
                    localStorage.removeItem('token');
                    window.location.href = 'login.html';
                }
            } catch (e) {
                localStorage.removeItem('token');
                window.location.href = 'login.html';
            }
        }

        // ============================================
        // LOAD DATA
        // ============================================
        async function loadData() {
            try {
                // Load products
                var productRes = await fetch(API_URL + '/api/products', {
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                if (productRes.ok) {
                    allProducts = await productRes.json();
                }

                // Load variants
                var variantRes = await fetch(API_URL + '/api/product-variants', {
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                if (variantRes.ok) {
                    allVariants = await variantRes.json();
                }

                renderAll();
                populateProductSelect();

            } catch (e) {
                console.error('Error loading data:', e);
                showToast('Error loading stock data', 'error');
            }
        }

        // ============================================
        // RENDER ALL
        // ============================================
        function renderAll() {
            updateStats();
            updateCategoryCounts();
            renderProducts();
        }

        // ============================================
        // UPDATE STATS
        // ============================================
        function updateStats() {
            var totalEggs = 0, birds = 0, feedTotal = 0, meds = 0, totalValue = 0;
            var lowStockItems = [];

            for (var i = 0; i < allVariants.length; i++) {
                var v = allVariants[i];
                var qty = v.quantity || 0;
                var price = v.price || 0;
                var threshold = v.threshold || 10;
                var cat = v.category || getCategoryFromProduct(v.product_id);

                if (cat === 'egg') totalEggs += qty;
                else if (cat === 'bird') birds += qty;
                else if (cat === 'feed') feedTotal += qty;
                else if (cat === 'med') meds++;

                totalValue += qty * price;

                if (qty < threshold && qty > 0) {
                    lowStockItems.push({ name: v.variant_name, qty: qty, threshold: threshold });
                }
            }

            var turnover = allVariants.length > 0 ? (allVariants.reduce(function(s, v) { return s + (v.quantity || 0); }, 0) / (allVariants
                .length || 1)) : 0;
            var turnoverDisplay = turnover > 0 ? (turnover / 50).toFixed(1) + 'x' : '0.0x';

            var dailyFeedConsumption = Math.max(Math.round(birds * 0.15), 1);
            var feedDays = feedTotal > 0 ? Math.round(feedTotal / dailyFeedConsumption) : 0;

            var lowStockDisplay = lowStockItems.length > 0 ?
                lowStockItems.slice(0, 2).map(function(item) {
                    return item.name + ': ' + item.qty + ' (' + item.threshold + ' min)';
                }).join(', ') + (lowStockItems.length > 2 ? ' +' + (lowStockItems.length - 2) + ' more' : '') :
                'All items in stock';

            document.getElementById('statTotalEggs').textContent = totalEggs;
            document.getElementById('statBirds').textContent = birds;
            document.getElementById('statFeed').textContent = feedTotal + ' kg';
            document.getElementById('statMeds').textContent = meds;
            document.getElementById('statTotalValue').textContent = formatCurrency(totalValue);
            document.getElementById('statTurnover').textContent = turnoverDisplay;
            document.getElementById('statLowStock').textContent = lowStockItems.length;
            document.getElementById('statLowStock').style.color = lowStockItems.length > 0 ? '#DC3545' : '#28A745';
            document.getElementById('lowStockDetails').innerHTML = lowStockDisplay;
            document.getElementById('statFeedDays').textContent = feedDays;
            document.getElementById('statFeedDays').style.color = feedDays < 5 ? '#DC3545' : feedDays < 14 ? '#856404' :
            '#28A745';
        }

        function getCategoryFromProduct(productId) {
            var product = allProducts.find(function(p) { return p.id === productId; });
            return product ? product.category : 'unknown';
        }

        // ============================================
        // UPDATE CATEGORY COUNTS
        // ============================================
        function updateCategoryCounts() {
            var counts = { all: allProducts.length, bird: 0, feed: 0, egg: 0, med: 0, equip: 0, pack: 0 };
            for (var i = 0; i < allProducts.length; i++) {
                var cat = allProducts[i].category;
                if (counts[cat] !== undefined) counts[cat]++;
            }
            document.getElementById('countAll').textContent = counts.all;
            document.getElementById('countBird').textContent = counts.bird;
            document.getElementById('countFeed').textContent = counts.feed;
            document.getElementById('countEgg').textContent = counts.egg;
            document.getElementById('countMed').textContent = counts.med;
            document.getElementById('countEquip').textContent = counts.equip || 0;
            document.getElementById('countPack').textContent = counts.pack || 0;
        }

        // ============================================
        // RENDER PRODUCTS
        // ============================================
        function renderProducts() {
            var container = document.getElementById('productGrid');
            var filteredProducts = allProducts;

            if (currentCategory !== 'all') {
                filteredProducts = allProducts.filter(function(p) {
                    return p.category === currentCategory;
                });
            }

            if (filteredProducts.length === 0) {
                container.innerHTML = '<div class="empty-state"><span class="icon">📦</span><p>No products found. Add your first product!</p></div>';
                return;
            }

            var html = '';
            for (var i = 0; i < filteredProducts.length; i++) {
                var p = filteredProducts[i];
                var variants = allVariants.filter(function(v) { return v.product_id === p.id; });
                var totalQty = variants.reduce(function(sum, v) { return sum + (v.quantity || 0); }, 0);
                var catClass = getCategoryClass(p.category);
                var variantRows = '';

                if (variants.length === 0) {
                    variantRows = '<tr><td colspan="7" style="text-align:center;padding:8px;color:#888;font-size:11px;">No variants added yet</td></tr>';
                } else {
                    for (var j = 0; j < variants.length; j++) {
                        var v = variants[j];
                        var statusClass = '';
                        var statusText = '';
                        if (v.quantity === 0) { statusClass = 'out-of-stock';
                            statusText = 'Out of Stock'; } else if (v.quantity < v.threshold) { statusClass = 'low-stock';
                            statusText = '⚠️ Low Stock'; } else { statusText = '✅ In Stock'; }

                        variantRows += '<tr>';
                        variantRows += '<td class="variant-name">' + (v.variant_name || '-') + '</td>';
                        variantRows += '<td>' + (v.supplier || '-') + '</td>';
                        variantRows += '<td>' + (v.quantity || 0) + '</td>';
                        variantRows += '<td>' + (v.unit || '-') + '</td>';
                        variantRows += '<td>' + formatCurrency(v.price) + '</td>';
                        variantRows += '<td class="' + statusClass + '">' + statusText + '</td>';
                        variantRows += '<td>';
                        variantRows += '<button class="action-btn-sm edit" onclick="editVariant(' + v.id + ')">Edit</button>';
                        variantRows += '<button class="action-btn-sm delete" onclick="deleteVariant(' + v.id + ')">Delete</button>';
                        variantRows += '</td>';
                        variantRows += '</tr>';
                    }
                }

                html += '<div class="product-card">';
                html += '<div class="product-header" onclick="toggleProduct(this)">';
                html += '<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">';
                html += '<span class="product-name">' + (p.name || 'Unnamed') + '</span>';
                html += '<span class="product-category ' + catClass + '">' + getCategoryLabel(p.category) + '</span>';
                html += '</div>';
                html += '<div style="display:flex;align-items:center;gap:10px;">';
                html += '<span class="product-total">Total: <strong>' + totalQty + '</strong> ' + (variants.length > 0 ? variants[0]
                    .unit || 'units' : 'units') + '</span>';
                html += '<button class="product-toggle" onclick="event.stopPropagation();toggleProduct(this.parentElement)">▼</button>';
                html += '</div>';
                html += '</div>';
                html += '<div class="variant-table-wrap">';
                html += '<table class="variant-table">';
                html += '<thead><tr><th>Variant</th><th>Supplier</th><th>Qty</th><th>Unit</th><th>Price</th><th>Status</th><th>Actions</th></tr></thead>';
                html += '<tbody>' + variantRows + '</tbody>';
                html += '</table>';
                html += '</div>';
                html += '</div>';
            }

            container.innerHTML = html;
        }

        // ============================================
        // TOGGLE PRODUCT EXPAND
        // ============================================
        function toggleProduct(element) {
            var tableWrap = element.nextElementSibling;
            var toggle = element.querySelector('.product-toggle');
            if (tableWrap.style.display === 'none') {
                tableWrap.style.display = 'block';
                toggle.classList.remove('open');
                toggle.textContent = '▼';
            } else {
                tableWrap.style.display = 'none';
                toggle.classList.add('open');
                toggle.textContent = '▶';
            }
        }

        // ============================================
        // FILTER BY CATEGORY
        // ============================================
        function filterByCategory(cat) {
            currentCategory = cat;
            document.querySelectorAll('.category-btn').forEach(function(el) {
                el.classList.toggle('active', el.getAttribute('data-category') === cat);
            });
            renderProducts();
        }

        // ============================================
        // POPULATE PRODUCT SELECT
        // ============================================
        function populateProductSelect() {
            var select = document.getElementById('variantProductSelect');
            select.innerHTML = '<option value="">Select product...</option>';
            for (var i = 0; i < allProducts.length; i++) {
                var p = allProducts[i];
                var option = document.createElement('option');
                option.value = p.id;
                option.textContent = p.name + ' (' + getCategoryLabel(p.category) + ')';
                select.appendChild(option);
            }
        }

        // ============================================
        // PRODUCT MODAL
        // ============================================
        function openAddProductModal() {
            document.getElementById('productModalTitle').textContent = 'Add Product';
            document.getElementById('editProductId').value = '';
            document.getElementById('productName').value = '';
            document.getElementById('productCategory').value = 'feed';
            document.getElementById('productDescription').value = '';
            document.getElementById('productModal').classList.add('show');
        }

        function closeProductModal() {
            document.getElementById('productModal').classList.remove('show');
        }

        async function saveProduct(event) {
            event.preventDefault();
            var id = document.getElementById('editProductId').value;
            var name = document.getElementById('productName').value.trim();
            var category = document.getElementById('productCategory').value;
            var description = document.getElementById('productDescription').value.trim();

            if (!name) { showToast('Product name is required', 'error'); return; }

            var data = { name: name, category: category, description: description };
            var url = API_URL + '/api/products';
            var method = 'POST';
            if (id) { url = API_URL + '/api/products/' + id;
                method = 'PUT'; }

            try {
                var res = await fetch(url, {
                    method: method,
                    headers: {
                        'Authorization': 'Bearer ' + token,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });
                if (res.ok) {
                    showToast(id ? 'Product updated!' : 'Product added!', 'success');
                    closeProductModal();
                    loadData();
                } else {
                    var result = await res.json();
                    showToast(result.error || 'Failed to save product', 'error');
                }
            } catch (e) {
                showToast('Network error', 'error');
            }
        }

        // ============================================
        // VARIANT MODAL
        // ============================================
        function openAddVariantModal(productId) {
            document.getElementById('variantModalTitle').textContent = 'Add Variant';
            document.getElementById('editVariantId').value = '';
            document.getElementById('variantProductId').value = '';
            document.getElementById('variantName').value = '';
            document.getElementById('variantSupplier').value = '';
            document.getElementById('variantUnit').value = '';
            document.getElementById('variantQuantity').value = '';
            document.getElementById('variantPrice').value = '';
            document.getElementById('variantThreshold').value = '10';
            document.getElementById('variantExpiry').value = '';
            if (productId) {
                document.getElementById('variantProductSelect').value = productId;
            } else {
                document.getElementById('variantProductSelect').value = '';
            }
            document.getElementById('variantModal').classList.add('show');
        }

        function closeVariantModal() {
            document.getElementById('variantModal').classList.remove('show');
        }

        async function saveVariant(event) {
            event.preventDefault();
            var id = document.getElementById('editVariantId').value;
            var product_id = document.getElementById('variantProductSelect').value;
            var variant_name = document.getElementById('variantName').value.trim();
            var supplier = document.getElementById('variantSupplier').value.trim();
            var unit = document.getElementById('variantUnit').value.trim();
            var quantity = parseFloat(document.getElementById('variantQuantity').value);
            var price = parseFloat(document.getElementById('variantPrice').value) || 0;
            var threshold = parseInt(document.getElementById('variantThreshold').value) || 10;
            var expiry = document.getElementById('variantExpiry').value;

            if (!product_id) { showToast('Please select a product', 'error'); return; }
            if (!variant_name) { showToast('Variant name is required', 'error'); return; }
            if (!unit) { showToast('Unit is required', 'error'); return; }
            if (isNaN(quantity)) { showToast('Quantity is required', 'error'); return; }

            var data = {
                product_id: parseInt(product_id),
                variant_name: variant_name,
                supplier: supplier || null,
                unit: unit,
                quantity: quantity,
                price: price,
                threshold: threshold,
                expiry_date: expiry || null
            };

            var url = API_URL + '/api/product-variants';
            var method = 'POST';
            if (id) { url = API_URL + '/api/product-variants/' + id;
                method = 'PUT'; }

            try {
                var res = await fetch(url, {
                    method: method,
                    headers: {
                        'Authorization': 'Bearer ' + token,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });
                if (res.ok) {
                    showToast(id ? 'Variant updated!' : 'Variant added!', 'success');
                    closeVariantModal();
                    loadData();
                } else {
                    var result = await res.json();
                    showToast(result.error || 'Failed to save variant', 'error');
                }
            } catch (e) {
                showToast('Network error', 'error');
            }
        }

        // ============================================
        // EDIT VARIANT
        // ============================================
        async function editVariant(id) {
            var variant = allVariants.find(function(v) { return v.id === id; });
            if (!variant) { showToast('Variant not found', 'error'); return; }

            document.getElementById('variantModalTitle').textContent = 'Edit Variant';
            document.getElementById('editVariantId').value = variant.id;
            document.getElementById('variantProductSelect').value = variant.product_id;
            document.getElementById('variantName').value = variant.variant_name || '';
            document.getElementById('variantSupplier').value = variant.supplier || '';
            document.getElementById('variantUnit').value = variant.unit || '';
            document.getElementById('variantQuantity').value = variant.quantity || '';
            document.getElementById('variantPrice').value = variant.price || '';
            document.getElementById('variantThreshold').value = variant.threshold || '10';
            document.getElementById('variantExpiry').value = variant.expiry_date || '';
            document.getElementById('variantModal').classList.add('show');
        }

        // ============================================
        // DELETE VARIANT
        // ============================================
        async function deleteVariant(id) {
            if (!confirm('Are you sure you want to delete this variant?')) return;

            try {
                var res = await fetch(API_URL + '/api/product-variants/' + id, {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                if (res.ok) {
                    showToast('Variant deleted!', 'success');
                    loadData();
                } else {
                    var result = await res.json();
                    showToast(result.error || 'Failed to delete variant', 'error');
                }
            } catch (e) {
                showToast('Network error', 'error');
            }
        }

        // ============================================
        // LOGOUT
        // ============================================
        document.getElementById('logoutBtn').addEventListener('click', function(e) {
            e.preventDefault();
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            window.location.href = 'login.html';
        });

        // ============================================
        // INIT
        // ============================================
        loadUser();
        loadData();
    </script>
</body>

</html>
