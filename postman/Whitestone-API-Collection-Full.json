{
  "info": {
    "name": "Whitestone API - Full Collection",
    "description": "Complete Whitestone API with Stock endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"},
            "url": {"raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"]}
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"]}
          }
        }
      ]
    },
    {
      "name": "Stock",
      "item": [
        {
          "name": "Get All Stock",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/stock", "host": ["{{base_url}}"], "path": ["api", "stock"]}
          }
        },
        {
          "name": "Get Stock Item",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/stock/1", "host": ["{{base_url}}"], "path": ["api", "stock", "1"]}
          }
        },
        {
          "name": "Create Stock Item",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n    \"name\": \"Layer Mash\",\n    \"category\": \"Feed\",\n    \"quantity\": 450,\n    \"unit\": \"kg\",\n    \"value\": 675,\n    \"min_threshold\": 50\n}"},
            "url": {"raw": "{{base_url}}/api/stock", "host": ["{{base_url}}"], "path": ["api", "stock"]}
          }
        },
        {
          "name": "Update Stock Item",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n    \"name\": \"Layer Mash Premium\",\n    \"category\": \"Feed\",\n    \"quantity\": 500,\n    \"unit\": \"kg\",\n    \"value\": 750,\n    \"min_threshold\": 50\n}"},
            "url": {"raw": "{{base_url}}/api/stock/1", "host": ["{{base_url}}"], "path": ["api", "stock", "1"]}
          }
        },
        {
          "name": "Delete Stock Item",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/stock/1", "host": ["{{base_url}}"], "path": ["api", "stock", "1"]}
          }
        },
        {
          "name": "Get Stock Movements",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/stock/movements", "host": ["{{base_url}}"], "path": ["api", "stock", "movements"]}
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{base_url}}/api/employees", "host": ["{{base_url}}"], "path": ["api", "employees"]}
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "base_url", "value": "http://localhost:5500", "type": "string"},
    {"key": "token", "value": "", "type": "string"}
  ]
}
