{
  "info": {
    "name": "WhiteStone Farm API",
    "_postman_id": "whitestone-api-collection",
    "description": "WhiteStone Poultry Farm Management System API - Auto-detects port",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Auto-detect server port",
          "const host = pm.environment.get('host') || 'localhost';",
          "const savedPort = pm.environment.get('port');",
          "",
          "if (savedPort) {",
          "    pm.environment.set('baseUrl', http://System.Management.Automation.Internal.Host.InternalHost:);",
          "    return;",
          "}",
          "",
          "const ports = [5500, 5501, 5502, 5503, 3000, 5000];",
          "",
          "(async function detectServer() {",
          "    for (const port of ports) {",
          "        try {",
          "            const response = await pm.sendRequest({",
          "                url: http://System.Management.Automation.Internal.Host.InternalHost:/api/health,",
          "                method: 'GET',",
          "                timeout: 1000",
          "            });",
          "            if (response.code === 200) {",
          "                pm.environment.set('port', port);",
          "                pm.environment.set('baseUrl', http://System.Management.Automation.Internal.Host.InternalHost:);",
          "                console.log(✅ Server detected on port );",
          "                return;",
          "            }",
          "        } catch(e) {}",
          "    }",
          "    console.log('⚠️ No server found, using port 5500');",
          "    pm.environment.set('port', '5500');",
          "    pm.environment.set('baseUrl', 'http://localhost:5500');",
          "})();",
          "",
          "// Auto-add token to requests",
          "if (!pm.request.url.path.includes('login') && !pm.request.url.path.includes('register')) {",
          "    const token = pm.environment.get('token');",
          "    if (token) {",
          "        pm.request.headers.add({",
          "            key: 'Authorization',",
          "            value: Bearer ",
          "        });",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "// Save token from login response",
          "if (pm.response.code === 200) {",
          "    const response = pm.response.json();",
          "    if (response.token) {",
          "        pm.environment.set('token', response.token);",
          "        console.log('✅ Token saved');",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"Admin123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Employees",
      "item": [
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Health Check",
      "item": [
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5500",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
